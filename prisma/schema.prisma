generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TRAINER
  CLIENT
}

enum UserAuthState {
  ACTIVE
  MIGRATED_PASSWORD_REQUIRED
}

enum NotificationType {
  MESSAGE
  TRAINING_PLAN
  WORKOUT_PLAN
  NUTRITION_PLAN
  WORKOUT
  CHECKIN
  REQUEST
  SYSTEM
}

model User {
  id                      String          @id @default(cuid())
  email                   String          @unique
  passwordHash            String
  role                    UserRole
  authState               UserAuthState   @default(ACTIVE)
  fullName                String
  isActive                Boolean         @default(true)
  legacySupabaseProfileId String?         @unique
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  trainerProfile          TrainerProfile?
  clientProfile           ClientProfile?
  notifications           Notification[]
  sentMessages            Message[]       @relation("MessageSender")
  receivedMessages        Message[]       @relation("MessageReceiver")
}

model TrainerProfile {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients     ClientProfile[]
  linkTokens  ClientLinkToken[]
  workoutPlans WorkoutPlan[]
  foods       Food[]
  recipes     Recipe[]
  nutritionPlans NutritionPlan[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ClientProfile {
  id                     String         @id @default(cuid())
  userId                 String?        @unique
  user                   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  trainerId              String
  trainer                TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  fullName               String
  email                  String
  phone                  String?
  notes                  String?
  status                 String         @default("active")
  legacySupabaseClientId String?        @unique
  legacySupabaseUserId   String?        @unique
  assignedPlans          AssignedPlan[]
  assignedNutritionPlans AssignedNutritionPlan[]
  clientMealFoods        ClientMealFood[]
  mealHistory            MealHistory[]
  mealLogs               MealLog[]
  drinkLogs              DrinkLog[]
  workoutLogs            WorkoutLog[]
  exerciseChangeRequests ExerciseChangeRequest[]
  progressLogs           ProgressLog[]
  weeklyCheckins         WeeklyCheckin[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([trainerId])
}

model ClientLinkToken {
  id         String         @id @default(cuid())
  trainerId  String
  trainer    TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  email      String
  tokenHash  String         @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([trainerId])
  @@index([email])
}

model WorkoutPlan {
  id            String          @id @default(cuid())
  trainerId     String
  trainer       TrainerProfile  @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  name          String
  description   String?
  isActive      Boolean         @default(true)
  legacySupabasePlanId String?  @unique
  days          WorkoutDay[]
  assignedPlans AssignedPlan[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([trainerId])
}

model AssignedPlan {
  id         String        @id @default(cuid())
  clientId   String
  planId     String
  assignedAt DateTime      @default(now())
  active     Boolean       @default(true)
  legacySupabaseAssignedPlanId String? @unique
  client     ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan       WorkoutPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([clientId, active])
  @@index([planId, active])
  @@unique([clientId, planId])
}

model WorkoutDay {
  id          String      @id @default(cuid())
  planId      String
  plan        WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int         @default(0)
  legacySupabaseDayId String? @unique
  exercises              Exercise[]
  workoutLogs            WorkoutLog[]
  exerciseChangeRequests ExerciseChangeRequest[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([planId, sortOrder])
}

model Exercise {
  id            String      @id @default(cuid())
  dayId          String
  day            WorkoutDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  sets           Int
  reps           String
  targetWeightKg Float?
  restSeconds    Int?
  note           String?
  sortOrder      Int         @default(0)
  imageUrl       String?
  legacySupabaseExerciseId String? @unique
  exerciseLogs           ExerciseLog[]
  exerciseChangeRequests ExerciseChangeRequest[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([dayId, sortOrder])
}

model ExerciseLibrary {
  id          String   @id @default(cuid())
  name        String
  muscleGroup String?
  equipment   String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Food {
  id                   String            @id @default(cuid())
  trainerId            String?
  trainer              TrainerProfile?   @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  name                 String
  caloriesPer100g      Float?
  proteinPer100g       Float?
  carbsPer100g         Float?
  fatPer100g           Float?
  unit                 String?
  category             String?
  brand                String?
  barcode              String?           @unique
  defaultServingG      Float?
  source               String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  legacySupabaseFoodId String?           @unique
  clientMealFoods      ClientMealFood[]

  @@index([trainerId])
  @@index([name])
  @@index([category])
  @@index([brand])
}

model Recipe {
  id                     String          @id @default(cuid())
  trainerId              String?
  trainer                TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  name                   String
  description            String?
  instructions           String?
  imageUrl               String?
  ingredients            Json?
  servings               Int?
  totalCalories          Float?
  proteinG               Float?
  carbsG                 Float?
  fatG                   Float?
  sourcePdf              String?
  category               String?
  prepTimeMinutes        Int?
  cookTimeMinutes        Int?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  legacySupabaseRecipeId String?         @unique

  @@index([trainerId])
  @@index([name])
  @@index([category])
  @@index([sourcePdf])
}

model NutritionPlan {
  id                             String                  @id @default(cuid())
  trainerId                      String
  trainer                        TrainerProfile          @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  name                           String
  description                    String?
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
  legacySupabaseNutritionPlanId  String?                 @unique
  meals                          NutritionMeal[]
  assignedNutritionPlans         AssignedNutritionPlan[]

  @@index([trainerId])
}

model NutritionMeal {
  id                             String            @id @default(cuid())
  planId                         String
  plan                           NutritionPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  name                           String
  description                    String?
  sortOrder                      Int               @default(0)
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  legacySupabaseNutritionMealId  String?           @unique
  clientMealFoods                ClientMealFood[]

  @@index([planId, sortOrder])
}

model AssignedNutritionPlan {
  id                                       String         @id @default(cuid())
  clientId                                 String
  client                                   ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId                                   String
  plan                                     NutritionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  active                                   Boolean        @default(true)
  assignedAt                               DateTime       @default(now())
  legacySupabaseAssignedNutritionPlanId    String?        @unique

  @@unique([clientId, planId])
  @@index([clientId, active])
  @@index([planId])
}

model ClientMealFood {
  id                                String          @id @default(cuid())
  clientId                          String
  client                            ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mealId                            String?
  meal                              NutritionMeal?  @relation(fields: [mealId], references: [id], onDelete: SetNull)
  foodId                            String?
  food                              Food?           @relation(fields: [foodId], references: [id], onDelete: SetNull)
  category                          String?
  amountG                           Float?
  createdAt                         DateTime        @default(now())
  updatedAt                         DateTime        @updatedAt
  legacySupabaseClientMealFoodId    String?         @unique

  @@index([clientId])
  @@index([mealId])
  @@index([foodId])
}

model MealHistory {
  id                           String        @id @default(cuid())
  clientId                     String
  client                       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                         String?
  category                     String?
  amountG                      Float?
  calories                     Float?
  protein                      Float?
  carbs                        Float?
  fat                          Float?
  loggedAt                     DateTime      @default(now())
  legacySupabaseMealHistoryId  String?       @unique

  @@index([clientId, loggedAt])
}

model MealLog {
  id                       String        @id @default(cuid())
  clientId                 String
  client                   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date                     String
  mealType                 String?
  notes                    String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  legacySupabaseMealLogId  String?       @unique

  @@index([clientId, date])
}

model DrinkLog {
  id                        String        @id @default(cuid())
  clientId                  String
  client                    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  drinkType                 String?
  amountMl                  Float?
  loggedAt                  DateTime      @default(now())
  legacySupabaseDrinkLogId  String?       @unique

  @@index([clientId, loggedAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([userId, isRead, createdAt])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  readAt     DateTime?
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([senderId])
  @@index([receiverId, readAt])
}

model WorkoutLog {
  id              String        @id @default(cuid())
  clientId        String
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dayId           String
  day             WorkoutDay    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  date            String
  notes           String?
  completedAt     DateTime?
  durationSeconds Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  exerciseLogs    ExerciseLog[]

  @@index([clientId, completedAt])
  @@index([clientId, dayId, completedAt])
}

model ExerciseLog {
  id           String     @id @default(cuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  actualWeight Float?
  actualReps   String?
  setsDone     Int?
  completed    Boolean    @default(false)
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([workoutLogId, exerciseId, setsDone])
  @@index([workoutLogId])
}

model ExerciseChangeRequest {
  id         String        @id @default(cuid())
  clientId   String
  client     ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dayId      String
  day        WorkoutDay    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  reason     String
  status     String        @default("pending")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([clientId])
  @@index([dayId])
}

model ProgressLog {
  id                          String        @id @default(cuid())
  clientId                    String
  client                      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date                        String
  bodyWeight                  Float?
  notes                       String?
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  legacySupabaseProgressLogId String?       @unique

  @@index([clientId, date])
}

model WeeklyCheckin {
  id                              String         @id @default(cuid())
  clientId                        String
  client                          ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weekStart                       String
  mood                            Int?
  energy                          Int?
  sleepQuality                    Int?
  hunger                          Int?
  stress                          Int?
  bodyWeight                      Float?
  comment                         String?
  images                          CheckinImage[]
  createdAt                       DateTime       @default(now())
  updatedAt                       DateTime       @updatedAt
  legacySupabaseWeeklyCheckinId   String?        @unique

  @@unique([clientId, weekStart])
  @@index([clientId, weekStart])
}

model CheckinImage {
  id                            String        @id @default(cuid())
  checkinId                     String
  checkin                       WeeklyCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  storagePath                   String
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt
  legacySupabaseCheckinImageId  String?       @unique

  @@index([checkinId])
}
