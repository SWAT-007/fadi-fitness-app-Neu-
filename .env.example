# ─── Backend ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Express port (default: 4000)
PORT=4000

# Set to "production" on the server
NODE_ENV=production

# ─── Frontend (Next.js server-side) ───────────────────────────────────────────

# Internal URL the Next.js server uses to reach the Express backend.
# In production this is usually the private/internal service URL.
BACKEND_API_URL=http://localhost:4000

# ─── Frontend (public — baked into browser bundle at build time) ──────────────

# Public URL of the Express backend, used by the browser to load
# checkin images (/uploads/...). Also required for APK builds.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ─── CORS (backend) ───────────────────────────────────────────────────────────

# Primary production frontend origin (e.g. https://yourapp.com)
FRONTEND_ORIGIN=

# Optional extra origins, comma-separated (e.g. https://staging.yourapp.com)
ADDITIONAL_CORS_ORIGINS=

# ─── PWA ──────────────────────────────────────────────────────────────────────

# Set to "true" to disable PWA service worker (useful on Windows dev)
DISABLE_PWA=false
